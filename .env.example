# Google Service Account credentials for Sheets and Drive API
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Spreadsheet ID (from the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your-google-spreadsheet-id-here

# Google Drive folder ID for uploaded PDF files
# Find it in the URL when viewing the folder: https://drive.google.com/drive/folders/DRIVE_FOLDER_ID
DRIVE_FOLDER_ID=your-google-drive-folder-id-here
